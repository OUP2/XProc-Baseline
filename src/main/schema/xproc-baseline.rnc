namespace b = "http://ns.oup.com/xproc/baseline"

start = (regression-tests | manifest.element)

regression-tests =
  element b:regression-tests {
    element b:imports {
      element b:import {
        attribute href { text }
      }+
    },
    element b:config { config.global & config.all },
    test+
  }
  
config.global =
  element b:test-harness {
    attribute href { xsd:anyURI }
  },
  element b:hash {
    attribute algorithm { "md" | "sha" | "crc" }
  }?
  
config.all =
  element b:canonicalization {
    attribute pipeline { xsd:NMTOKEN }
  }*
  
manifest = 
  manifest.element | 
  attribute manifest-href { xsd:anyURI }
  
manifest.element = element b:manifest { manifest.folder | manifest.zip | manifest.file }

manifest.folder = element b:folder {
  attribute name { text },
  ( manifest.folder | manifest.zip | manifest.file )*
}

manifest.file = element b:file{
  manifest.attributes,
  attribute size { text }?,
  attribute hash { text }?
}

manifest.zip = element b:archive{
  manifest.attributes,
  ( manifest.folder | manifest.zip | manifest.file )* 
}

manifest.attributes = (
  attribute name { text },
  attribute content-type { text }?,
  attribute compression-method { text }?
)

test =
  element b:test {
    attribute pipeline { xsd:NMTOKEN },
    attribute xml:id { xsd:NCName },
    element b:description { text },
    element b:config { config.all }?,
    element b:options {
      element b:option {
        attribute name { xsd:NCName },
        attribute select { text }
      }+
    }?,
    element b:input { empty }?,
    element b:baseline {
      attribute uri {xsd:anyURI},
      manifest?
    }
  }
