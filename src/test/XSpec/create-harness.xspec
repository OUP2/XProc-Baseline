<?xml version="1.0" encoding="UTF-8"?>
<x:description
  xmlns:xs="http://www.w3.org/2001/XMLSchema"
  xmlns:p="http://www.w3.org/ns/xproc"
  xmlns:c="http://www.w3.org/ns/xproc-step"
  xmlns:x="http://www.jenitennison.com/xslt/xspec"
  xmlns:b="http://ns.oup.com/xproc/baseline"
  xmlns:bc="http://ns.oup.com/xproc/baseline_canon"
  stylesheet="../../main/XSLT/create-harness.xsl"
  run-as="external">

  <x:scenario label="GIVEN a URL to the baseline XProc library">
    <x:param name="baseline-xproc-uri" select="resolve-uri('../../../main/xproc/Baseline.xpl')"/>
    
    <x:scenario label="WHEN matching in the default mode">
      
      <x:scenario label="GIVEN a sample 'swtest' XProc Baseline test definition">
        <x:param name="config-uri" select="resolve-uri('../../baseline/swtest.xml')"/>
        <x:context href="../baseline/swtest.xml"/>
        
        <x:expect label="EXPECT to import to the XProc library to be tested" test="/p:library/p:import[contains(@href, 'sw_test1.xpl')]">
          <p:import href="../xproc/sw_test1.xpl"/>
        </x:expect>
        
      </x:scenario>

      <x:scenario label="GIVEN a sample 'dogfood' XProc Baseline test definition">
        <x:param name="config-uri" select="resolve-uri('../../baseline/dogfood.xml')"/>
        <x:context href="../baseline/dogfood.xml"/>

        <x:expect label="EXPECT an XProc library">
          <p:library exclude-inline-prefixes="#all" version="...">...</p:library>
        </x:expect>
        <x:expect label="EXPECT a '3.0' version" test="/p:library/@version eq '3.0'"/>
        
        <x:expect label="EXPECT to suppress the import to the specified baseline XProc library" test="empty(/p:library/p:import[ends-with(@href, 'main/xproc/Baseline.xpl')])"/>

        <x:expect label="EXPECT to convert any other imports to the XProc namespace" test="/p:library/p:import">
          <p:import href="../../main/xproc/Baseline-canon.xpl"/>
        </x:expect>
        
        <x:expect label="EXPECT to convert step definitions from the baseline XProc library" test="exists(/p:library/p:declare-step[@type='b:create-manifest'])"/>
        
        <x:expect label="EXPECT to add/copy a step for canonicalization" test="/p:library/p:declare-step[@type='b:canon']">
          <p:declare-step type="b:canon">...</p:declare-step>
        </x:expect>
        
        <x:expect label="EXPECT to add relevant canonicalization options for named tests to the b:canon step" test="/p:library/p:declare-step[@type='b:canon']/p:choose/p:when[contains(@test, 'xzr_w35_z3c')]">
          <p:when test="$test-id eq 'xzr_w35_z3c'">
            <bc:timestamps/>
          </p:when>
        </x:expect>
        
        <x:expect label="EXPECT to add global canonicalization options for named tests without specific canonicalization options" test="p:library/p:declare-step[@type='b:canon']/p:choose/p:otherwise">
          <p:otherwise>
            <bc:UUIDs/>
          </p:otherwise>
        </x:expect>
        
        <x:expect label="EXPECT to create a 'run-test' step" test="/p:library/p:declare-step[@type='b:run-test']">
          <p:declare-step type="b:run-test">...</p:declare-step>
        </x:expect>
        
        <x:expect label="EXPECT the 'run-test' step to have a test-id option" test="/p:library/p:declare-step[@type='b:run-test']/p:option[@name eq 'test-id']">
          <p:option name="test-id" required="true"/>
        </x:expect>
        
        <x:expect label="EXPECT the first step within 'run-test' to be a named identity step 'original'" test="/p:library/p:declare-step[@type='b:run-test']/p:option[@name eq 'test-id']/following-sibling::*[1]">
          <p:identity name="original"/>
        </x:expect>
        
        <x:expect label="EXPECT to create a step to run the named test (e.g. 'xzr_w35_z3c')" test="/p:library/p:declare-step[@type='b:run-test']/p:choose/p:when[contains(@test, 'xzr_w35_z3c')]">
          <p:when test="$test-id = 'xzr_w35_z3c'">...</p:when>
        </x:expect>
        
        <x:expect pending="curly braces causing false negatives" label="EXPECT to create a step to report the result as the first declare step" test="/p:library/p:declare-step[1]">
          <p:declare-step type="b:report">
            <p:input port="source" primary="true"/>
            <p:output port="result" primary="true" sequence="true"/>
            <p:variable name="test_uri" select="base-uri()"/>

            <p:identity/>

            <p:viewport match="b:test[@xml:id][b:output]">
              <p:variable name="test-id" select="/*/@xml:id" as="xs:string"/>
              <p:delete match="b:output/b:manifest"/>
              <p:identity name="test"/>
              <b:run-test test-id="..."/>
              <b:create-manifest path="..." test-id="..."/>
              <p:identity name="output_manifest"/>
              <p:insert match="b:output" position="first-child">
                <p:with-input port="source" pipe="@test"/>
                <p:with-input port="insertion" pipe="@output_manifest"/>
              </p:insert>
            </p:viewport>
            <p:identity name="manifest_compare"/>

            <p:if test="$b:report-formats = 'junit'">
              <p:xslt>
                <p:with-input port="source" pipe="@manifest_compare"/>
                <p:with-input port="stylesheet" href="../../main/XSLT/junit.xsl"/>
              </p:xslt>
              <p:store href="..."/>
            </p:if>

          </p:declare-step>
        </x:expect>
        
        <x:expect label="EXPECT to update relative URIs in XSLT href attributes (i.e. from '../' to '../../main')"
          test="/p:library/p:declare-step[@type='b:create-harness']/p:xslt/p:with-input[1]/@href eq '../../main/XSLT/create-harness.xsl'"/>

      </x:scenario>
      
      <x:scenario label="GIVEN a b:test with an option but no input">
        <x:context>
          <b:test pipeline="b:create-manifest" xml:id="xzr_w35_z3c">
            <b:description>Regression test for manifest creation from a file or folder</b:description>
            <b:config>
              <b:canonicalization pipeline="bc:timestamps"/>
            </b:config>
            <b:options>
              <b:option name="path" select="'../data/Input/manifest-creation/'"/>
            </b:options>
            <b:baseline uri="../data/Input/manifest-creation/" manifest-href="../data/baseline/manifest-creation.bmx"/>
          </b:test>
        </x:context>
        <x:expect label="EXPECT to create a 'when' step to run the named test (e.g. 'xzr_w35_z3c')" test="/p:when[contains(@test, 'xzr_w35_z3c')]">
          <p:when test="$test-id = 'xzr_w35_z3c'">...</p:when>
        </x:expect>
        <x:expect label="EXPECT to explicitly set the output" test="/p:when/*[1]">
          <p:output pipe="result@test-output"/>
        </x:expect>
        <x:expect label="EXPECT to set the primary input to empty" test="/p:when/*[2]">
          <p:identity>
            <p:with-input>
              <p:empty/>
            </p:with-input>
          </p:identity>
        </x:expect>
        <x:expect label="EXPECT to run the specified 'create-manifest' test from that step" test="/p:when/*[3]">
          <b:create-manifest>...</b:create-manifest>
        </x:expect>
        <x:expect label="EXPECT to set the specified 'path' option with p:with-option" test="/p:when/b:create-manifest/p:with-option">
          <p:with-option name="path" select="'../data/Input/manifest-creation/'"/>
        </x:expect>
        <x:expect label="EXPECT to set an identity for the output to connect to" test="/p:when/*[last()]">
          <p:identity name="test-output">
            <p:with-input pipe="result@original"/>
          </p:identity> 
        </x:expect>
      </x:scenario> 
      <x:scenario label="GIVEN a b:test with no options but an input href">
        <x:context>
          <b:test pipeline="b:create-harness" xml:id="test_shx_mpl_bjc">
            <b:description>Regression test for harness creation from a file or folder</b:description>
            <b:input port="source" href="dogfood.xml"/>
            <b:baseline uri="../data/baseline/test-harness/baseline_test-harness.xpl"/>
          </b:test>
        </x:context>
        <x:expect label="EXPECT to create a 'when' step to run the named test (e.g. 'test_shx_mpl_bjc')" test="/p:when[contains(@test, 'test_shx_mpl_bjc')]">
          <p:when test="$test-id = 'test_shx_mpl_bjc'">...</p:when>
        </x:expect>
        <x:expect label="EXPECT to explicitly set the output" test="/p:when/*[1]">
          <p:output pipe="result@test-output"/>
        </x:expect>
        <x:expect label="EXPECT to set the primary input to empty" test="/p:when/*[2]">
          <p:identity>
            <p:with-input>
              <p:empty/>
            </p:with-input>
          </p:identity>
        </x:expect>
        <x:expect label="EXPECT to run the b:create-harness step" test="/p:when/*[3]">
          <b:create-harness>...</b:create-harness>
        </x:expect>
        <x:expect label="EXPECT to set the input(s) using the configuration in b:input" test="/p:when/b:create-harness/p:with-input">
          <p:with-input port="source" href="dogfood.xml"/>
        </x:expect>
        <x:expect label="EXPECT to set an identity for the output to connect to" test="/p:when/*[last()]">
          <p:identity name="test-output">
            <p:with-input pipe="result@original"/>
          </p:identity> 
        </x:expect>
        
      </x:scenario>
      <x:scenario label="GIVEN a b:test with no options but an input document">
        <x:context>
          <b:test pipeline="b:create-harness" xml:id="test_shx_mpl_bjc">
            <b:description>Regression test for harness creation from a file or folder</b:description>
            <b:input port="source">
              <b:document href="dogfood.xml"/>
            </b:input>
            <b:baseline uri="../data/baseline/test-harness/baseline_test-harness.xpl"/>
          </b:test>
        </x:context>
      </x:scenario>
      
    </x:scenario>
    
    <x:scenario label="WHEN matching in the 'copy' mode" pending="TFJH: problems resolving URIs in XSpec">
      <x:context mode="copy"/>

      <x:scenario label="GIVEN a generic step definition from the baseline XProc library">
        <x:context expand-text="false">
          <p:declare-step type="b:create-manifest">
            <p:option name="path" required="true"/>
            <p:output port="result" primary="true" serialization="..."/>

            <p:file-info href="..."/>
            <b:manifest-process/>
            <p:xslt>
              <p:with-input port="stylesheet" href="../XSLT/manifest.xsl"/>
            </p:xslt>
            <p:wrap match="/" wrapper="b:manifest"/>
          </p:declare-step>
        </x:context>
        <x:expect label="EXPECT the step to be copied unchanged">
          <p:declare-step type="b:create-manifest">
            <p:option name="path" required="true"/>
            <p:output port="result" primary="true" serialization="..."/>

            <p:file-info href="..."/>
            <b:manifest-process/>
            <p:xslt>
              <p:with-input port="stylesheet" href="../XSLT/manifest.xsl"/>
            </p:xslt>
            <p:wrap match="/" wrapper="b:manifest"/>
          </p:declare-step>
        </x:expect>
      </x:scenario>

      <x:scenario label="GIVEN an option from the baseline XProc library">
        <x:context>
          <p:option name="b:hash-algorithm" select="'crc'" static="true"/>
        </x:context>
        <x:expect label="EXPECT to copy the option unchanged">
          <p:option name="b:hash-algorithm" select="'crc'" static="true"/>
        </x:expect>
      </x:scenario>
      
    </x:scenario>

    <x:scenario label="WHEN matching in the 'btop' mode">
      <x:context mode="btop"/>
      
      <x:scenario label="GIVEN a node in the b: namespace">
        <x:context>
          <b:wibble>
            <b:wobble foo='bar'/>
          </b:wibble>
        </x:context>
        <x:expect label="EXPECT to output the same element but in the p:namespace">
          <p:wibble>
            <p:wobble foo='bar'/>
          </p:wibble>
        </x:expect>
      </x:scenario>
      
      <x:scenario label="GIVEN a node not in the b:namespace">
        <x:context>
          <foo>bar</foo>
        </x:context>
        <x:expect label="EXPECT it to be copied to the output">
          <foo>bar</foo>
        </x:expect>
      </x:scenario>
      
      <x:scenario label="GIVEN a mixed set of nodes">
        <x:context>
          <b:foo>
            <bar/>
          </b:foo>
        </x:context>
        <x:expect label="EXPECT nodes to be copied, changing b: nodes to p: nodes">
          <p:foo>
            <bar/>
          </p:foo>
        </x:expect>
      </x:scenario>
      
    </x:scenario>

  </x:scenario>

  <x:scenario label="WHEN testing the b:relativeUri function">
    <x:call function="b:relativeUri"/>
    
    <x:scenario label="GIVEN the base URI 'file:/Projects/XProc-Baseline/src/test/XSpec/create-harness.xspec'">
      
      <x:scenario label="GIVEN the target URI 'file:/Projects/XProc-Baseline/src/test/xproc/sw_test1.xpl'">
        <x:call>
          <x:param name="target" select="'file:/Projects/XProc-Baseline/src/test/xproc/sw_test1.xpl'"/>
          <x:param name="base" select="'file:/Projects/XProc-Baseline/src/test/XSpec/create-harness.xspec'"/>
        </x:call>
        <x:expect label="EXPECT the relative URL '../xproc/sw_test1.xpl'" select="'../xproc/sw_test1.xpl'"/>
      </x:scenario>
      
    </x:scenario>

    <x:scenario label="GIVEN the base URI 'file:/Projects/XProc-Baseline/src/test/data/baseline/test-harness/'">

      <x:scenario label="GIVEN the target URI 'file:/Projects/XProc-Baseline/src/main/xproc/Baseline.xpl'">
        <x:call>
          <x:param name="target" select="'file:/Projects/XProc-Baseline/src/main/xproc/Baseline.xpl'"/>
          <x:param name="base" select="'file:/Projects/XProc-Baseline/src/test/data/baseline/test-harness/'"/>
        </x:call>
        <x:expect label="EXPECT the relative URL '../../../../main/xproc/Baseline.xpl'" select="'../../../../main/xproc/Baseline.xpl'"/>
      </x:scenario>

      <x:scenario label="GIVEN the target URI 'file:/Projects/XProc-Baseline/src/main/xproc/'">
        <x:call>
          <x:param name="target" select="'file:/Projects/XProc-Baseline/src/main/xproc/'"/>
          <x:param name="base" select="'file:/Projects/XProc-Baseline/src/test/data/baseline/test-harness/'"/>
        </x:call>
        <x:expect label="EXPECT the relative URL '../../../../main/xproc/'" select="'../../../../main/xproc/'"/>
      </x:scenario>

    </x:scenario>
    
    <x:scenario label="GIVEN the base URI 'file:///Projects/XProc-Baseline/src/test/data/baseline/test-harness/'">
      
      <x:scenario label="GIVEN the target URI 'file:/Projects/XProc-Baseline/src/main/xproc/Baseline.xpl''">
        <x:call>
          <x:param name="target" select="'file:/Projects/XProc-Baseline/src/main/xproc/Baseline.xpl'"/>
          <x:param name="base" select="'file:///Projects/XProc-Baseline/src/test/data/baseline/test-harness/'"/>
        </x:call>
        <x:expect label="EXPECT the relative URL '../../../../main/xproc/Baseline.xpl'" select="'../../../../main/xproc/Baseline.xpl'"/>
      </x:scenario>
      
    </x:scenario>

    <x:scenario label="GIVEN the base URI 'file:/Projects/XProc-Baseline/src/test/data/baseline/test-harness/somefile.xpl'">

      <x:scenario label="GIVEN the target URI 'file:/Projects/XProc-Baseline/src/main/xproc/Baseline.xpl'">
        <x:call>
          <x:param name="target" select="'file:/Projects/XProc-Baseline/src/main/xproc/Baseline.xpl'"/>
          <x:param name="base" select="'file:/Projects/XProc-Baseline/src/test/data/baseline/test-harness/somefile.xpl'"/>
        </x:call>
        <x:expect label="EXPECT the relative URL '../../../../main/xproc/Baseline.xpl'" select="'../../../../main/xproc/Baseline.xpl'"/>
      </x:scenario>

      <x:scenario label="GIVEN the target URI 'file:/Projects/XProc-Baseline/src/main/xproc/'">
        <x:call>
          <x:param name="target" select="'file:/Projects/XProc-Baseline/src/main/xproc/'"/>
          <x:param name="base" select="'file:/Projects/XProc-Baseline/src/test/data/baseline/test-harness/'"/>
        </x:call>
        <x:expect label="EXPECT the relative URL '../../../../main/xproc/'" select="'../../../../main/xproc/'"/>
      </x:scenario>

    </x:scenario>

  </x:scenario>
  
  <x:scenario pending="TFJH: errors with java.lang.ArrayStoreException" label="WHEN testing the b:changeRelativeBase function">
    <x:call function="b:changeRelativeBase"/>
    <x:scenario label="GIVEN a relative URL and two base-uris">
      <x:call>
        <x:param name="relativeURI" select="'../XSLT/create-harness.xspec'"/>
        <x:param name="oldBase" select="'/src/main/xproc/Baseline.xpl'"/>
        <x:param name="newBase" select="'/src/test/baseline/baseline_test-harness.xpl'"/>
      </x:call>
      
      <x:expect label="THEN return the new relative url" select="'../../main/XSLT/create-harness.xspec'"/>
    </x:scenario>
  </x:scenario>

</x:description>